# Copy to config.env on the host and edit.
#   cp config.env.example config.env

# Dedicated clone of the repo the runner works in (NOT your interactive checkout).
# The runner hard-resets this tree between jobs.
REPO_DIR="$HOME/queue-ai/repo"

# Optional: set before first bootstrap if the clone does not exist yet.
# REPO_URL="git@github.com:YOU/YOUR_REPO.git"

# Default base branch (overridable per job).
BASE_BRANCH="main"

# Optional ntfy topic URL for push when a job finishes.
# NTFY_URL="http://localhost:8080/queue-ai"

# Claude CLI model ids (subscription catalog).
# Example ids: claude-sonnet-5, claude-opus-4-8, claude-haiku-4-5-20251001, claude-fable-5
CLAUDE_MODEL="claude-sonnet-5"
CLAUDE_REVIEW_MODEL="claude-opus-4-8"
# 1 = run annotate-only review when implement produced a diff; 0 = skip
CLAUDE_REVIEW="1"

# Optional shell hooks (empty = skip). Run from REPO_DIR.
# PREPARE_CMD='pnpm install --frozen-lockfile'
# VALIDATE_CMD='pnpm test'

# Packet mode (opt-in): a job with a PLAN slug and no PROMPT compiles a work order
# and gates the result. These three vars are the only project-specific touchpoints;
# defaults target a plans-as-code toolchain. Placeholders: {slug}, {base}.
#   PACKET_COMPILE_CMD      — build the packet JSON in the fresh clone
#   PACKET_JSON_PATH        — where the compiled packet JSON lands
#   PACKET_CONFORMANCE_CMD  — validate gate (non-zero → PR opened but flagged)
# PACKET_COMPILE_CMD='pnpm -s plan:readiness -- {slug} && pnpm -s plan:packet -- {slug}'
# PACKET_JSON_PATH='.temp/agent-os/packets/{slug}/packet.json'
# PACKET_CONFORMANCE_CMD='pnpm -s plan:conformance -- {slug} --base origin/{base} --head HEAD'

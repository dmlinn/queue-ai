#!/usr/bin/env bash
# desktop — laptop cockpit for an always-on Linux host
#            (Claude Code overnight runner, power, health).
#
#   desktop              list commands
#   desktop help         same
#   desktop <cmd> -h     help for one command
#
# Host SSH alias: DESKTOP_HOST (default: desktop)
# WoL: set DESKTOP_MAC (and optional DESKTOP_BCAST) before using wake
set -euo pipefail

HOST="${DESKTOP_HOST:-desktop}"
MAC="${DESKTOP_MAC:-}"
BCAST="${DESKTOP_BCAST:-255.255.255.255}"
RUNNER_ROOT='~/desktop-runner'

ssh_batch() {
  ssh -o ConnectTimeout=8 -o BatchMode=yes "$HOST" "$@"
}

ssh_tty() {
  ssh -t "$HOST" "$@"
}

cmd_help() {
  cat <<'HELP'
desktop — control an always-on Linux box from this laptop

Usage:  desktop <command> [args]

Power
  sleep [--setup|--force|--keep-mask|--interactive]
                      Suspend the machine (prefer deep S3, not s2idle)
  wake [--no-wait]    Wake-on-LAN (magic packet) and wait for SSH
  ssh [args...]       Interactive SSH (pass-through)

Runner
  dispatch <name> [base]   Queue a job (PROMPT via stdin or flags)
  status                   Queue / service / last log / usage tail
  logs                     Follow newest runner log (Ctrl-C to stop)
  usage [--sum|--all]      Efficiency ledger (minutes + API-est $)

Health
  doctor              Connectivity, sleep mode, runner, GPU snapshot
  ping                Can we SSH right now?

Help
  help | -h | --help  This list
  commands            Subcommand names only

Examples
  desktop
  desktop doctor
  desktop dispatch fix-readme main --prompt 'Fix typos in README.md only'
  desktop status
  desktop sleep
  desktop wake

Env
  DESKTOP_HOST   SSH Host alias (default: desktop)
  DESKTOP_MAC    NIC MAC for WoL (required for wake), e.g. aa:bb:cc:dd:ee:ff
  DESKTOP_BCAST  broadcast address (default: 255.255.255.255)
HELP
}

cmd_commands() {
  printf '%s\n' \
    help commands doctor ping ssh \
    sleep wake \
    dispatch status logs usage
}

cmd_ping() {
  if ssh_batch 'echo ok' 2>/dev/null; then
    echo "up  ($HOST)"
    return 0
  fi
  echo "down ($HOST) — try: desktop wake"
  return 1
}

cmd_ssh() {
  exec ssh -t "$HOST" "$@"
}

cmd_status() {
  ssh_batch "bash $RUNNER_ROOT/bin/status.sh"
}

cmd_logs() {
  ssh_tty "f=\$(ls -1t $RUNNER_ROOT/logs/*.log 2>/dev/null | head -1); [ -n \"\$f\" ] && tail -f \"\$f\" || echo 'no logs yet'"
}

cmd_dispatch() {
  local name="" base="main" prompt="" prompt_file="" title=""
  local -a rest=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help)
        cat <<'DHELP'
Usage:
  desktop dispatch <name> [base] --prompt 'one-line instructions'
  desktop dispatch <name> [base] --prompt-file path/in/repo.md
  desktop dispatch <name> [base]   # then type PROMPT=... on stdin

Job fields on the host (sourced as shell):
  PLAN (label), BASE, PROMPT or PROMPT_FILE, optional TITLE
DHELP
        return 0
        ;;
      --prompt)
        prompt="${2:-}"; shift 2 || true
        ;;
      --prompt-file)
        prompt_file="${2:-}"; shift 2 || true
        ;;
      --title)
        title="${2:-}"; shift 2 || true
        ;;
      --)
        shift
        rest+=("$@")
        break
        ;;
      -*)
        echo "unknown flag: $1" >&2
        return 1
        ;;
      *)
        rest+=("$1")
        shift
        ;;
    esac
  done

  name="${rest[0]:-}"
  base="${rest[1]:-main}"
  if [ -z "$name" ]; then
    echo "Usage: desktop dispatch <name> [base]  (see desktop dispatch -h)" >&2
    return 1
  fi

  # stdin PROMPT if not given via flags and stdin is not a tty
  if [ -z "$prompt" ] && [ -z "$prompt_file" ] && [ ! -t 0 ]; then
    prompt="$(cat)"
    # allow full job body on stdin (PLAN= already known); if it looks like KEY=
    if [[ "$prompt" != PROMPT=* && "$prompt" != *"PROMPT="* ]]; then
      # plain text → wrap
      :
    fi
  fi

  local queued_at queued_by part job_body
  queued_at="$(date -u +%FT%TZ)"
  queued_by="$(scutil --get ComputerName 2>/dev/null || hostname)"
  part=".${name}.$$.part"

  if [ -n "$prompt_file" ]; then
    job_body="$(printf 'PLAN=%q\nBASE=%q\nPROMPT_FILE=%q\nTITLE=%q\nQUEUED_AT=%q\nQUEUED_BY=%q\n' \
      "$name" "$base" "$prompt_file" "$title" "$queued_at" "$queued_by")"
  elif [ -n "$prompt" ]; then
    # If stdin was a full job file with PROMPT=..., pass through carefully
    if [[ "$prompt" == PROMPT=* || "$prompt" == *$'\n'PROMPT=* ]]; then
      # User supplied KEY=value body; ensure PLAN/BASE present
      job_body="$(printf 'PLAN=%q\nBASE=%q\nQUEUED_AT=%q\nQUEUED_BY=%q\n' \
        "$name" "$base" "$queued_at" "$queued_by")"
      job_body+=$'\n'"$prompt"
      if [ -n "$title" ]; then
        job_body+=$'\n'"TITLE=$(printf %q "$title")"
      fi
    else
      job_body="$(printf 'PLAN=%q\nBASE=%q\nPROMPT=%q\nTITLE=%q\nQUEUED_AT=%q\nQUEUED_BY=%q\n' \
        "$name" "$base" "$prompt" "$title" "$queued_at" "$queued_by")"
    fi
  else
    echo "Need a prompt: pipe PROMPT=…, or --prompt, or --prompt-file" >&2
    return 1
  fi

  ssh_batch "mkdir -p $RUNNER_ROOT/queue && cat > $RUNNER_ROOT/queue/${part} && mv $RUNNER_ROOT/queue/${part} $RUNNER_ROOT/queue/${name}.job" <<<"$job_body"
  echo "queued '${name}' (base=${base}) → ${HOST}"
  echo "watch: desktop status  |  desktop logs"
}

cmd_usage() {
  local mode="${1:-}"
  # shellcheck disable=SC2029
  ssh_batch "MODE=$(printf %q "$mode") bash -s" <<'REMOTE'
LEDGER="$HOME/desktop-runner/ledger.jsonl"
if [ ! -f "$LEDGER" ]; then
  echo "no ledger yet at $LEDGER"
  exit 0
fi
case "${MODE:-}" in
  --all|-a)
    while IFS= read -r line; do
      node -e 'const r=JSON.parse(process.argv[1]); const t=r.totals||{}; const i=r.implement||{}; const v=r.review||{};
        console.log([r.ts,r.job,"rc="+r.rc,"wall_min="+t.wall_min,"est_usd="+t.cost_usd_est,"impl="+(i.model||"—"),"rev="+(v.model||"—"),r.pr||""].join("\t"));
      ' "$line"
    done < "$LEDGER"
    ;;
  --sum|-s)
    node -e '
      const fs=require("fs");
      const lines=fs.readFileSync(process.argv[1],"utf8").trim().split("\n").filter(Boolean);
      let cost=0, wall=0, n=0;
      const byModel={};
      for (const line of lines) {
        const r=JSON.parse(line); n++;
        const t=r.totals||{};
        cost += t.cost_usd_est||0;
        wall += t.wall_ms||0;
        for (const p of [r.implement, r.review]) {
          if (!p||!p.model) continue;
          const m=byModel[p.model]||{cost:0,ms:0,n:0};
          m.cost += p.total_cost_usd_est||0;
          m.ms += p.duration_ms||0;
          m.n++;
          byModel[p.model]=m;
        }
      }
      console.log("jobs="+n+" wall_min="+(wall/60000).toFixed(2)+" est_usd_total="+cost.toFixed(4));
      console.log("by model:");
      for (const [model,m] of Object.entries(byModel)) {
        console.log("  "+model+": n="+m.n+" wall_min="+(m.ms/60000).toFixed(2)+" est_usd="+m.cost.toFixed(4));
      }
      console.log("(est. \$ is API-equivalent, not subscription billing)");
    ' "$LEDGER"
    ;;
  -h|--help) echo "Usage: desktop usage [--sum|--all]" ;;
  *)
    echo "last 10 ledger rows (API-equivalent est.):"
    tail -10 "$LEDGER" | while IFS= read -r line; do
      node -e 'const r=JSON.parse(process.argv[1]); const t=r.totals||{}; const i=r.implement||{}; const v=r.review||{};
        console.log((r.ts||"").slice(0,19), r.job, "wall="+t.wall_min+"m", "est=$"+t.cost_usd_est, "impl="+(i.model||"—"), "rev="+(v.model||"—"), r.pr||"");
      ' "$line"
    done
    echo "tips: desktop usage --sum | desktop usage --all"
    ;;
esac
REMOTE
}

cmd_wake() {
  local wait=1
  for arg in "$@"; do
    case "$arg" in
      --no-wait|-n) wait=0 ;;
      -h|--help)
        echo "Usage: desktop wake [--no-wait]"
        echo "Requires DESKTOP_MAC (magic packet only — not random LAN traffic)."
        return 0
        ;;
    esac
  done

  if [ -z "$MAC" ]; then
    echo "Set DESKTOP_MAC=aa:bb:cc:dd:ee:ff (host NIC MAC) before wake." >&2
    return 1
  fi

  if ssh -o ConnectTimeout=2 -o BatchMode=yes "$HOST" 'echo awake' 2>/dev/null; then
    echo "already awake ($HOST)"
    return 0
  fi

  python3 - "$MAC" "$BCAST" <<'PY'
import socket, sys
mac_s, bcast = sys.argv[1], sys.argv[2]
mac = bytes.fromhex(mac_s.replace(":", "").replace("-", ""))
if len(mac) != 6:
    raise SystemExit(f"bad MAC: {mac_s}")
pkt = b"\xff" * 6 + mac * 16
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
for dest in (bcast, "255.255.255.255"):
    try:
        s.sendto(pkt, (dest, 9))
    except OSError as e:
        print(f"warn {dest}: {e}", file=sys.stderr)
print(f"WoL magic packet → {mac_s}")
PY

  if [ "$wait" -eq 0 ]; then
    return 0
  fi

  echo -n "waiting for SSH"
  local _
  for _ in $(seq 1 30); do
    if ssh -o ConnectTimeout=2 -o BatchMode=yes "$HOST" 'echo awake' 2>/dev/null; then
      echo
      echo "desktop is up"
      return 0
    fi
    echo -n "."
    sleep 2
  done
  echo
  echo "packet sent but SSH not up after ~60s. Check BIOS WoL + ethtool wol g."
  return 1
}

cmd_sleep() {
  local force=0 keep_mask=0 setup=0 interactive=0
  for arg in "$@"; do
    case "$arg" in
      --force|-f) force=1 ;;
      --keep-mask) keep_mask=1 ;;
      --setup|--allow-passwordless) setup=1 ;;
      --interactive|-i) interactive=1 ;;
      -h|--help)
        cat <<EOF
Usage: desktop sleep [options]
  --setup         install polkit rule for passwordless remote suspend
  --force         sleep even if runner has jobs
  --keep-mask     do not unmask suspend.target
  --interactive   ssh -t + systemctl suspend
EOF
        return 0
        ;;
    esac
  done

  if ! ssh_batch 'true' 2>/dev/null; then
    echo "cannot reach $HOST — already asleep or offline."
    return 1
  fi

  if [ "$setup" -eq 1 ]; then
    echo "Installing polkit passwordless-suspend rule on $HOST..."
    ssh_tty 'bash -s' <<'REMOTE'
set -euo pipefail
USER_NAME="$(id -un)"
RULE="/etc/polkit-1/rules.d/49-desktop-runner-suspend.rules"
TMP="$(mktemp)"
cat >"$TMP" <<EOF
// desktop-runner — allow ${USER_NAME} suspend/hibernate without interactive polkit
polkit.addRule(function(action, subject) {
    if (subject.user !== "${USER_NAME}") return;
    var ids = [
        "org.freedesktop.login1.suspend",
        "org.freedesktop.login1.suspend-multiple-sessions",
        "org.freedesktop.login1.hibernate",
        "org.freedesktop.login1.hibernate-multiple-sessions"
    ];
    if (ids.indexOf(action.id) >= 0) return polkit.Result.YES;
});
EOF
sudo install -m 644 "$TMP" "$RULE"
rm -f "$TMP"
sudo systemctl reload polkit 2>/dev/null || true
busctl call org.freedesktop.login1 /org/freedesktop/login1 org.freedesktop.login1.Manager CanSuspend
echo "Done. Try: desktop sleep"
REMOTE
    return 0
  fi

  if [ "$force" -eq 0 ]; then
    local busy nq nr
    busy="$(ssh_batch '
      q=$(ls -A ~/desktop-runner/queue 2>/dev/null | wc -l)
      r=$(ls -A ~/desktop-runner/running 2>/dev/null | wc -l)
      echo "$q $r"
    ')"
    read -r nq nr <<<"$busy"
    if [ "${nq:-0}" -gt 0 ] || [ "${nr:-0}" -gt 0 ]; then
      echo "runner has work in flight (queue=$nq running=$nr). Use --force to override."
      return 1
    fi
  fi

  if [ "$keep_mask" -eq 0 ]; then
    local masked
    masked="$(ssh_batch 'systemctl is-enabled suspend.target 2>&1 || true')"
    if [[ "$masked" == *masked* ]]; then
      echo "suspend.target is masked. Unmasking..."
      ssh_tty 'sudo systemctl unmask sleep.target suspend.target hibernate.target hybrid-sleep.target' || return 1
    fi
  fi

  local can
  can="$(ssh_batch 'busctl call org.freedesktop.login1 /org/freedesktop/login1 org.freedesktop.login1.Manager CanSuspend 2>/dev/null' || true)"
  echo "CanSuspend: $can"
  echo "suspending $HOST..."

  do_batch() {
    ssh_batch 'busctl call org.freedesktop.login1 /org/freedesktop/login1 org.freedesktop.login1.Manager Suspend b true >/dev/null 2>&1'
  }
  do_interactive() {
    ssh_tty 'systemctl suspend'
  }

  if [ "$interactive" -eq 1 ]; then
    do_interactive || true
  else
    case "$can" in
      *yes*) do_batch || true ;;
      *challenge*|*auth*)
        echo "polkit needs auth — desktop sleep --setup once, or --interactive"
        [ -t 0 ] && do_interactive || return 1
        ;;
      *no*) echo "suspend not available"; return 1 ;;
      *) do_batch || true
         ssh_batch 'true' 2>/dev/null && [ -t 0 ] && do_interactive || true
         ;;
    esac
  fi

  sleep 3
  if ssh -o ConnectTimeout=2 -o BatchMode=yes "$HOST" 'true' 2>/dev/null; then
    echo "still reachable — suspend did not stick."
    return 1
  fi
  echo "desktop is asleep. Wake with: desktop wake"
}

cmd_doctor() {
  echo "== desktop doctor ($HOST) =="
  if ! ssh_batch 'true' 2>/dev/null; then
    echo "SSH:        DOWN  — try: desktop wake"
    return 1
  fi
  echo "SSH:        up"
  ssh_batch 'bash -s' <<'REMOTE'
set +e
echo -n "hostname:   "; hostname
echo -n "uptime:     "; uptime | sed 's/^ *//'
echo -n "mem_sleep:  "; cat /sys/power/mem_sleep 2>/dev/null
echo "            (want [deep] for quiet fans; s2idle keeps hardware warm)"
echo -n "suspend:    "; systemctl is-enabled suspend.target 2>&1
echo -n "linger:     "; loginctl show-user "$USER" -p Linger --value 2>/dev/null
echo -n "runner path:"; systemctl --user is-active desktop-runner.path 2>/dev/null
echo -n "runner svc: "; systemctl --user is-active desktop-runner.service 2>/dev/null
echo -n "CanSuspend: "; busctl call org.freedesktop.login1 /org/freedesktop/login1 org.freedesktop.login1.Manager CanSuspend 2>/dev/null
echo -n "claude:     "; command -v claude >/dev/null && claude --version 2>/dev/null | head -1 || echo missing
echo -n "gh:         "; gh auth status 2>&1 | head -1
echo -n "queue:      "; ls ~/desktop-runner/queue 2>/dev/null | wc -l | tr -d ' '; echo " pending"
if command -v nvidia-smi >/dev/null; then
  nvidia-smi --query-gpu=name,power.draw,temperature.gpu,fan.speed --format=csv,noheader 2>/dev/null | sed 's/^/gpu:        /'
fi
REMOTE
  echo "WoL MAC:    ${MAC:-"(set DESKTOP_MAC)"}"
}

main() {
  local cmd="${1:-}"
  if [ -z "$cmd" ] || [ "$cmd" = "help" ] || [ "$cmd" = "-h" ] || [ "$cmd" = "--help" ]; then
    cmd_help
    return 0
  fi
  shift || true
  case "$cmd" in
    commands) cmd_commands ;;
    doctor)   cmd_doctor "$@" ;;
    ping)     cmd_ping "$@" ;;
    ssh)      cmd_ssh "$@" ;;
    sleep)    cmd_sleep "$@" ;;
    wake)     cmd_wake "$@" ;;
    dispatch) cmd_dispatch "$@" ;;
    status)   cmd_status "$@" ;;
    logs)     cmd_logs "$@" ;;
    usage)    cmd_usage "$@" ;;
    *)
      echo "unknown command: $cmd" >&2
      echo "Run: desktop" >&2
      return 1
      ;;
  esac
}

main "$@"
